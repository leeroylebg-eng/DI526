    "# ── Likert-scale fluency rating ────────────────────────────────────\n",
    "chatbot_response = \"Apologies, but comprehend I do not. Could you rephrase your question?\"\n",
    "\n",
    "fluency_rating   = 2   # out of 5\n",
    "improved_version = \"I'm sorry, I didn't quite understand that. Could you please rephrase your question?\"\n",
    "\n",
    "print(\"=== Human Evaluation — Fluency Rating ===\")\n",
    "print(f\"\\nOriginal response:\")\n",
    "print(f'  \"{chatbot_response}\"')\n",
    "print(f\"\\nFluency rating: {fluency_rating}/5\")\n",
    "print()\n",
    "print(\"Justification:\")\n",
    "print(\"  Rating: 2/5 (Below Average)\")\n",
    "print(\"  - The phrase 'comprehend I do not' uses inverted Yoda-style syntax that is\")\n",
    "print(\"    grammatically unusual in standard English.\")\n",
    "print(\"  - The word 'comprehend' is overly formal and rarely used in conversational AI.\")\n",
    "print(\"  - The inversion makes the sentence sound robotic and confusing, which would\")\n",
    "print(\"    reduce user trust and create a poor conversational experience.\")\n",
    "print(\"  - It is technically grammatical (Yoda is a valid style), so it earns 2 not 1.\")\n",
    "print()\n",
    "print(f\"Improved version:\")\n",
    "print(f'  \"{improved_version}\"')\n",
    "print()\n",
    "print(\"Why it is better:\")\n",
    "print(\"  1. Natural word order ('I didn't quite understand') matches conversational norms.\")\n",
    "print(\"  2. 'understand' is simpler and more natural than 'comprehend'.\")\n",
    "print(\"  3. 'please' adds politeness without artificiality.\")\n",
    "print(\"  4. 'quite' softens the admission of confusion, making the interaction warmer.\")\n",
    "print(\"  5. Overall: sounds like a helpful assistant, not a malfunctioning robot.\")"
   ]
