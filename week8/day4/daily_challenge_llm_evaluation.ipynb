    "---\n",
    "## Task 2 — Applying BLEU and ROUGE Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "g7000007",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 2.1 BLEU Score ────────────────────────────────────────────────\n",
    "bleu_reference = (\n",
    "    \"Despite the increasing reliance on artificial intelligence in various industries, \"\n",
    "    \"human oversight remains essential to ensure ethical and effective implementation.\"\n",
    ")\n",
    "bleu_generated = (\n",
    "    \"Although AI is being used more in industries, \"\n",
    "    \"human supervision is still necessary for ethical and effective application.\"\n",
    ")\n",
    "\n",
    "# Tokenize\n",
    "ref_tokens  = [word_tokenize(bleu_reference.lower())]\n",
    "hyp_tokens  =  word_tokenize(bleu_generated.lower())\n",
    "\n",
    "# BLEU with smoothing (Chen & Cherry) to handle short n-gram matches\n",
    "smoother = SmoothingFunction()\n",
    "\n",
    "bleu_scores = {}\n",
    "for n in range(1, 5):\n",
    "    weights = tuple([1/n if i < n else 0 for i in range(4)])\n",
    "    score   = sentence_bleu(ref_tokens, hyp_tokens,\n",
    "                             weights=weights,\n",
    "                             smoothing_function=smoother.method1)\n",
    "    bleu_scores[f\"BLEU-{n}\"] = round(score, 4)\n",
    "\n",
    "print(\"=== BLEU Score Calculation ===\")\n",
    "print(f\"Reference : {bleu_reference}\")\n",
    "print(f\"Generated : {bleu_generated}\")\n",
    "print()\n",
    "for metric, score in bleu_scores.items():\n",
    "    print(f\"  {metric} : {score:.4f}  ({score*100:.2f}%)\")\n",
    "\n",
    "print()\n",
    "print(\"Interpretation:\")\n",
    "print(\"  BLEU-1 captures unigram overlap (individual words like 'industries', 'ethical', 'effective').\")\n",
    "print(\"  BLEU-2 rewards bigram pairs — but 'AI is being' ≠ 'artificial intelligence'\")\n",
    "print(\"  despite identical meaning, so BLEU-2 drops significantly.\")\n",
    "print(\"  BLEU-3/4 are near zero — the generated text paraphrases rather than copying.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "g7000008",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 2.2 ROUGE Score ───────────────────────────────────────────────\n",
    "rouge_reference = (\n",
    "    \"In the face of rapid climate change, global initiatives must focus on reducing \"\n",
    "    \"carbon emissions and developing sustainable energy sources to mitigate environmental impact.\"\n",
    ")\n",
    "rouge_generated = (\n",
    "    \"To counteract climate change, worldwide efforts should aim to lower carbon emissions \"\n",
    "    \"and enhance renewable energy development.\"\n",
    ")\n",
    "\n",
    "def compute_rouge(predictions, references, use_stemmer=True):\n",
    "    preds_fmt = [\"\\n\".join(nltk.sent_tokenize(p)) for p in predictions]\n",
    "    refs_fmt  = [\"\\n\".join(nltk.sent_tokenize(r)) for r in references]\n",
    "    return rouge_metric.compute(predictions=preds_fmt, references=refs_fmt,\n",
    "                                use_stemmer=use_stemmer)\n",
    "\n",
    "rouge_scores = compute_rouge([rouge_generated], [rouge_reference])\n",
    "\n",
    "print(\"=== ROUGE Score Calculation ===\")\n",
    "print(f\"Reference : {rouge_reference}\")\n",
    "print(f\"Generated : {rouge_generated}\")\n",
    "print()\n",
    "for k, v in rouge_scores.items():\n",
    "    print(f\"  {k:<12} : {v:.4f}  ({v*100:.2f}%)\")\n",
    "\n",
    "print()\n",
    "print(\"Interpretation:\")\n",
    "print(\"  ROUGE-1 is relatively high — many individual words are shared ('climate', 'change',\")\n",
    "print(\"  'carbon', 'emissions', 'energy'). These are content words central to the topic.\")\n",
    "print(\"  ROUGE-2 drops — bigrams like 'carbon emissions' appear in both, but paraphrases\")\n",
    "print(\"  ('worldwide efforts' vs 'global initiatives') prevent bigram matching.\")\n",
    "print(\"  ROUGE-L captures the longest common subsequence — penalises different word order.\")"
   ]
  },
