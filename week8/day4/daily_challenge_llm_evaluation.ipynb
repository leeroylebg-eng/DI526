    "# ── Radar chart — metric properties ───────────────────────────────\n",
    "# Rate each metric on 5 dimensions (1–5)\n",
    "metrics = [\"BLEU\", \"ROUGE-N\", \"BERTScore\", \"Perplexity\", \"Human Eval\"]\n",
    "dimensions = [\"Speed\", \"Semantic\\nsensitivity\", \"Factuality\\ndetection\",\n",
    "               \"Cost\\nefficiency\", \"Human\\ncorrelation\"]\n",
    "\n",
    "# Scores (1=low, 5=high)\n",
    "scores = {\n",
    "    \"BLEU\"       : [5, 1, 1, 5, 2],\n",
    "    \"ROUGE-N\"    : [5, 2, 1, 5, 3],\n",
    "    \"BERTScore\"  : [3, 4, 2, 4, 4],\n",
    "    \"Perplexity\" : [4, 3, 1, 5, 2],\n",
    "    \"Human Eval\" : [1, 5, 5, 1, 5],\n",
    "}\n",
    "\n",
    "N     = len(dimensions)\n",
    "theta = np.linspace(0, 2*np.pi, N, endpoint=False).tolist()\n",
    "theta += theta[:1]   # close the polygon\n",
    "\n",
    "colors_radar = [\"#4C72B0\", \"#DD8452\", \"#55A868\", \"#C44E52\", \"#8172B3\"]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 8), subplot_kw=dict(polar=True))\n",
    "for (metric, vals), color in zip(scores.items(), colors_radar):\n",
    "    vals_closed = vals + vals[:1]\n",
    "    ax.plot(theta, vals_closed, \"o-\", linewidth=1.5, color=color, label=metric)\n",
    "    ax.fill(theta, vals_closed, alpha=0.08, color=color)\n",
    "\n",
    "ax.set_xticks(theta[:-1])\n",
    "ax.set_xticklabels(dimensions, fontsize=10)\n",
    "ax.set_ylim(0, 5)\n",
    "ax.set_yticks([1, 2, 3, 4, 5])\n",
    "ax.set_yticklabels([\"1\", \"2\", \"3\", \"4\", \"5\"], fontsize=8)\n",
    "ax.set_title(\"Evaluation Metric Comparison\\n(Text Summarisation)\",\n",
    "             fontsize=13, fontweight=\"bold\", pad=20)\n",
    "ax.legend(loc=\"upper right\", bbox_to_anchor=(1.35, 1.15), fontsize=9)\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"metric_radar.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(\"Radar chart saved → metric_radar.png\")"
   ]
