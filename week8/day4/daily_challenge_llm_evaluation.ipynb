   "id": "g7000024",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Comparative analysis table ─────────────────────────────────────\n",
    "comparison = [\n",
    "    {\n",
    "        \"Metric\"         : \"BLEU\",\n",
    "        \"Type\"           : \"Content overlap\",\n",
    "        \"Measures\"       : \"Precision of n-gram matches (1–4)\",\n",
    "        \"Strengths\"      : \"Fast, cheap, reproducible; good for MT where output ≈ reference\",\n",
    "        \"Weaknesses\"     : \"Ignores recall; punishes paraphrases; poorly correlated with human judgement for summarisation\",\n",
    "        \"Good for summ?\" : \"★★☆☆☆\",\n",
    "    },\n",
    "    {\n",
    "        \"Metric\"         : \"ROUGE-N\",\n",
    "        \"Type\"           : \"Content overlap\",\n",
    "        \"Measures\"       : \"Recall/F1 of n-gram overlap\",\n",
    "        \"Strengths\"      : \"Standard benchmark for summarisation; ROUGE-L captures fluency via LCS\",\n",
    "        \"Weaknesses\"     : \"Cannot assess factual accuracy; rewards verbose outputs; misses synonyms\",\n",
    "        \"Good for summ?\" : \"★★★☆☆\",\n",
    "    },\n",
    "    {\n",
    "        \"Metric\"         : \"BERTScore\",\n",
    "        \"Type\"           : \"Model-based (embedding)\",\n",
    "        \"Measures\"       : \"Cosine similarity of contextual BERT token embeddings\",\n",
    "        \"Strengths\"      : \"Handles synonyms and paraphrases; correlates better with human judgement; multilingual\",\n",
    "        \"Weaknesses\"     : \"Computationally heavier; depends on reference quality; no factuality check\",\n",
    "        \"Good for summ?\" : \"★★★★☆\",\n",
    "    },\n",
    "    {\n",
    "        \"Metric\"         : \"Perplexity\",\n",
    "        \"Type\"           : \"Model-based (language model)\",\n",
    "        \"Measures\"       : \"How surprised the LM is by the generated text\",\n",
    "        \"Strengths\"      : \"Evaluates fluency and coherence; no reference needed\",\n",
    "        \"Weaknesses\"     : \"Measures fluency, not relevance or factuality; high-PP text may be factually perfect; low-PP may be generic\",\n",
    "        \"Good for summ?\" : \"★★☆☆☆\",\n",
    "    },\n",
    "    {\n",
    "        \"Metric\"         : \"Human Evaluation\",\n",
    "        \"Type\"           : \"Human judgement\",\n",
    "        \"Measures\"       : \"Fluency, coherence, relevance, faithfulness, informativeness\",\n",
    "        \"Strengths\"      : \"Most comprehensive; can detect hallucinations, bias, tone; gold standard\",\n",
    "        \"Weaknesses\"     : \"Expensive, slow, non-reproducible; inter-annotator disagreement; not scalable\",\n",
    "        \"Good for summ?\" : \"★★★★★\",\n",
    "    },\n",
    "]\n",
    "\n",
    "df_compare = pd.DataFrame(comparison).set_index(\"Metric\")\n",
    "print(\"=== Comparative Analysis: Evaluation Metrics for Text Summarisation ===\")\n",
    "display(df_compare)"
   ]
