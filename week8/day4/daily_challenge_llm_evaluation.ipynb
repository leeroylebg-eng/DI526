    "---\n",
    "## Task 3 — Perplexity Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "g7000012",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 3.1 Perplexity for a single token ─────────────────────────────\n",
    "# Perplexity for a single token with probability p = 1/p\n",
    "# (for a sequence of N tokens: PP = (prod 1/p_i)^(1/N))\n",
    "\n",
    "p_model_A = 0.8   # Model A assigns P(\"mitigation\") = 0.8\n",
    "p_model_B = 0.4   # Model B assigns P(\"mitigation\") = 0.4\n",
    "\n",
    "# Single-token perplexity = 1 / p\n",
    "pp_A = 1 / p_model_A\n",
    "pp_B = 1 / p_model_B\n",
    "\n",
    "# Equivalent log-loss formulation: PP = exp(-log p)\n",
    "pp_A_log = math.exp(-math.log(p_model_A))\n",
    "pp_B_log = math.exp(-math.log(p_model_B))\n",
    "\n",
    "print(\"=== Perplexity Analysis ===\")\n",
    "print(f\"\\nModel A — P('mitigation') = {p_model_A}\")\n",
    "print(f\"  Perplexity = 1/{p_model_A} = {pp_A:.4f}\")\n",
    "print(f\"  (log form) = exp(-ln {p_model_A}) = {pp_A_log:.4f}\")\n",
    "\n",
    "print(f\"\\nModel B — P('mitigation') = {p_model_B}\")\n",
    "print(f\"  Perplexity = 1/{p_model_B} = {pp_B:.4f}\")\n",
    "print(f\"  (log form) = exp(-ln {p_model_B}) = {pp_B_log:.4f}\")\n",
    "\n",
    "winner = \"A\" if pp_A < pp_B else \"B\"\n",
    "print(f\"\\n→ Model {winner} has LOWER perplexity ({min(pp_A, pp_B):.4f} vs {max(pp_A, pp_B):.4f})\")\n",
    "print(f\"  because it assigns a HIGHER probability to the correct word.\")\n",
    "print(f\"  Lower perplexity = the model is less 'surprised' by the text = better fit.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "g7000013",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 3.2 Visualise: probability vs perplexity relationship ─────────\n",
    "probs = np.linspace(0.01, 0.99, 200)\n",
    "perplexities = 1 / probs\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 5))\n",
    "ax.plot(probs, perplexities, color=\"#4C72B0\", linewidth=2)\n",
    "\n",
    "# Annotate Model A and B\n",
    "for label, p, color in [(\"Model A (p=0.8)\", p_model_A, \"#55A868\"),\n",
    "                         (\"Model B (p=0.4)\", p_model_B, \"#C44E52\")]:\n",
    "    pp = 1 / p\n",
    "    ax.scatter([p], [pp], s=100, color=color, zorder=5)\n",
    "    ax.annotate(f\"{label}\\nPP={pp:.2f}\",\n",
    "                (p, pp), textcoords=\"offset points\", xytext=(10, 5),\n",
    "                fontsize=9, color=color, fontweight=\"bold\")\n",
    "\n",
    "ax.set_xlabel(\"Probability assigned to correct word\", fontsize=11)\n",
    "ax.set_ylabel(\"Perplexity\", fontsize=11)\n",
    "ax.set_title(\"Perplexity = 1/p  (lower probability → higher surprise)\",\n",
    "             fontsize=12, fontweight=\"bold\")\n",
    "ax.set_xlim(0, 1)\n",
    "ax.set_ylim(0, 20)\n",
    "ax.grid(True, linestyle=\"--\", alpha=0.4)\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"perplexity_curve.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(\"Chart saved → perplexity_curve.png\")"
   ]
