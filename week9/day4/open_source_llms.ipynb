    "- `mistralai/Mistral-7B-Instruct-v0.2` — https://huggingface.co/mistralai/Mistral-7B-Instruct-v0.2\n",
    "- `meta-llama/Llama-2-7b-chat-hf` — https://huggingface.co/meta-llama/Llama-2-7b-chat-hf"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
